rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserProfile() {
      return isAuthenticated() && exists(userDocPath());
    }

    function userDoc() {
      return get(userDocPath());
    }

    function isAccessEnabled() {
      return hasUserProfile() && userDoc().data.blocked != true;
    }

    function isAdmin() {
      return isAccessEnabled() && userDoc().data.role == 'admin';
    }

    function validRole(role) {
      return role in ['admin', 'OPERADOR'];
    }

    function validBlockedValue(blocked) {
      return blocked is bool;
    }

    function validCreateOwnership() {
      return request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function validUpdateOwnership() {
      return resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function validDestinacaoCreate() {
      return request.resource.data.processoId is string
        && request.resource.data.processoId.size() > 0
        && request.resource.data.entidadeId is string
        && request.resource.data.entidadeId.size() > 0
        && request.resource.data.entidadeNome is string
        && request.resource.data.entidadeNome.size() > 0
        && request.resource.data.solicitacaoData is string
        && request.resource.data.solicitacaoData.size() > 0
        && request.resource.data.competencia is string
        && request.resource.data.competencia.matches('^[0-1][0-9]/[0-9]{4}$')
        && request.resource.data.valorFomento is number
        && request.resource.data.valorFomento >= 0
        && request.resource.data.valorDestinado is number
        && request.resource.data.valorDestinado > 0
        && request.resource.data.valorPagoAcumulado is number
        && request.resource.data.valorPagoAcumulado == 0
        && request.resource.data.qtdPagamentos is number
        && request.resource.data.qtdPagamentos == 0
        && request.resource.data.statusPagamento == 'pendente'
        && request.resource.data.pgtoData == ''
        && request.resource.data.formaPgto == '';
    }

    function validDestinacaoUpdate() {
      return request.resource.data.processoId == resource.data.processoId
        && request.resource.data.termo == resource.data.termo
        && request.resource.data.empresa == resource.data.empresa
        && request.resource.data.produto == resource.data.produto
        && request.resource.data.valorFomento == resource.data.valorFomento
        && request.resource.data.solicitacaoData == resource.data.solicitacaoData
        && request.resource.data.entidadeId == resource.data.entidadeId
        && request.resource.data.entidadeNome == resource.data.entidadeNome
        && request.resource.data.valorDestinado == resource.data.valorDestinado
        && request.resource.data.competencia == resource.data.competencia
        && request.resource.data.statusPagamento in ['parcial', 'pago']
        && request.resource.data.valorPagoAcumulado is number
        && request.resource.data.valorPagoAcumulado > resource.data.valorPagoAcumulado
        && request.resource.data.valorPagoAcumulado <= resource.data.valorDestinado
        && request.resource.data.qtdPagamentos is number
        && request.resource.data.qtdPagamentos > resource.data.qtdPagamentos
        && request.resource.data.pgtoData is string
        && request.resource.data.pgtoData.size() > 0
        && request.resource.data.formaPgto is string
        && request.resource.data.formaPgto.size() > 0
        && (request.resource.data.statusPagamento == 'parcial'
          || request.resource.data.valorPagoAcumulado == request.resource.data.valorDestinado);
    }

    match /destinacoes/{document=**} {
      allow read: if isAccessEnabled();
      allow create: if isAccessEnabled() && validCreateOwnership() && validDestinacaoCreate();
      allow update: if isAccessEnabled() && (validUpdateOwnership() || isAdmin()) && validDestinacaoUpdate();
      allow delete: if false;
    }

    match /entidades/{document=**} {
      allow read: if isAccessEnabled();
      allow create: if isAccessEnabled() && validCreateOwnership();
      allow update: if isAccessEnabled() && validUpdateOwnership();
      allow delete: if false;
    }

    match /empresas/{document=**} {
      allow read: if isAccessEnabled();
      allow create: if isAccessEnabled() && validCreateOwnership();
      allow update: if isAccessEnabled() && validUpdateOwnership();
      allow delete: if false;
    }

    match /base_csv/{document=**} {
      allow read: if isAccessEnabled();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.uid == userId
        && validBlockedValue(request.resource.data.blocked)
        && (
          (
            request.auth.uid == userId
            && request.resource.data.role == 'OPERADOR'
            && request.resource.data.blocked == false
            && validCreateOwnership()
          )
          ||
          (
            isAdmin()
            && validRole(request.resource.data.role)
            && request.resource.data.createdBy == request.auth.uid
            && request.resource.data.updatedBy == request.auth.uid
          )
        );
      allow update: if isAuthenticated()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.updatedBy == request.auth.uid
        && validBlockedValue(request.resource.data.blocked)
        && (
          (
            request.auth.uid == userId
            && isAccessEnabled()
            && request.resource.data.role == resource.data.role
            && request.resource.data.blocked == resource.data.blocked
          )
          || (isAdmin() && validRole(request.resource.data.role))
        );
      allow delete: if false;
    }

    match /app_settings/{document=**} {
      allow read: if isAccessEnabled();
      allow write: if isAdmin();
    }
  }
}
